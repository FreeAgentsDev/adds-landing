---
const currentYear = new Date().getFullYear();
---
<footer class="relative border-t border-white/5 py-12 px-4">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
    <a href="#" class="flex items-center gap-2" aria-label="FreeAgents">
      <img src="/fa-logo.png" alt="FreeAgents" class="h-8 w-auto opacity-90" width="96" height="32" />
    </a>
    <p class="text-white/50 text-sm">
      © {currentYear} FreeAgents. Full Business Growth.
    </p>
    <div class="flex gap-6">
      <a href="#contacto" class="text-white/60 hover:text-neon-blue text-sm font-medium transition-colors">Contacto</a>
      <a href="#que-es" class="text-white/60 hover:text-neon-blue text-sm font-medium transition-colors">Qué es FreeAgents</a>
    </div>
  </div>
</footer>
