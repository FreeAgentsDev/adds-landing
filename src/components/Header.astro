---
const navLinks = [
  { href: '#full-business-growth', label: 'Full Business Growth' },
  { href: '#casos', label: 'Clientes' },
  { href: '#equipo', label: 'Equipo' },
  { href: '#proceso', label: 'Proceso' },
  { href: '#faq', label: 'FAQ' },
];
---
<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="mx-auto max-w-7xl px-4">
    <div class="flex items-center justify-between h-16 md:h-18">
      <a href="#" class="flex items-center gap-3 group" aria-label="FreeAgents inicio">
        <img src="/fa-logo.png" alt="FreeAgents" class="size-9 shrink-0 rounded-full object-cover ring-2 ring-primary/20 group-hover:ring-primary/50 transition-all" width="36" height="36" />
        <h2 class="text-white text-lg font-black tracking-tight">Free<span class="text-primary">Agents</span></h2>
      </a>
      <nav class="hidden md:flex gap-6 items-center">
        {navLinks.map((link) => (
          <a href={link.href} class="text-slate-400 hover:text-white transition-colors text-sm font-medium relative after:absolute after:bottom-0 after:left-0 after:h-px after:w-0 after:bg-primary hover:after:w-full after:transition-all">
            {link.label}
          </a>
        ))}
        <a href="#contacto" class="bg-primary text-background-dark px-5 py-2 rounded-lg font-bold text-sm hover:shadow-[0_0_15px_rgba(19,200,236,0.4)] hover:brightness-110 transition-all">
          Agendar
        </a>
      </nav>
      <button
        type="button"
        id="menu-toggle"
        class="md:hidden p-2 text-primary hover:bg-white/5 rounded-lg transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
      >
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 px-4 py-4 bg-background-dark/95 backdrop-blur-xl" aria-label="Menú móvil">
    <ul class="flex flex-col gap-1">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block py-3 px-3 rounded-lg text-slate-300 hover:text-white hover:bg-white/5 transition-all mobile-nav-link">
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-2">
        <a href="#contacto" class="block py-3 px-3 rounded-lg bg-primary/10 text-primary font-bold text-center mobile-nav-link">Agendar reunión</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('main-header');
  const links = document.querySelectorAll('.mobile-nav-link');

  function closeMenu() {
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    toggle?.setAttribute('aria-expanded', String(!menu?.classList.contains('hidden')));
  });

  links.forEach((link) => link.addEventListener('click', closeMenu));

  // Header background on scroll
  window.addEventListener('scroll', () => {
    if (header) {
      if (window.scrollY > 50) {
        header.classList.add('bg-background-dark/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
      } else {
        header.classList.remove('bg-background-dark/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
      }
    }
  }, { passive: true });
</script>
