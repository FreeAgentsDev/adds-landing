---
const navLinks = [
  { href: '#soluciones', label: 'Soluciones' },
  { href: '#proceso', label: 'Metodología' },
];
const CALENDLY_URL = 'https://calendly.com/freeagentsdev/30min';
---
<header class="sticky top-0 z-50 bg-background-dark/85 backdrop-blur-md border-b border-primary/10">
  <div class="max-w-7xl mx-auto flex items-center justify-between p-4">
    <a href="#" class="flex items-center gap-3" aria-label="FreeAgents inicio">
      <img src="/fa-logo.png" alt="FreeAgents" class="size-10 shrink-0 rounded-full object-cover" width="40" height="40" />
      <h2 class="text-white text-xl font-black tracking-tight">FreeAgents</h2>
    </a>
    <nav class="hidden md:flex gap-8 items-center">
      {navLinks.map((link) => (
        <a href={link.href} class="text-slate-300 hover:text-primary transition-colors text-sm font-medium">
          {link.label}
        </a>
      ))}
      <a href={CALENDLY_URL} target="_blank" rel="noopener noreferrer" class="bg-primary text-background-dark px-5 py-2 rounded-lg font-bold text-sm hover:brightness-110 transition-all">
        Agendar
      </a>
    </nav>
    <button
      type="button"
      id="menu-toggle"
      class="md:hidden p-2 text-primary"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú"
    >
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 px-4 py-4 bg-background-dark" aria-label="Menú móvil">
    <ul class="flex flex-col gap-2">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block py-2 text-slate-300 hover:text-primary transition-colors mobile-nav-link">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href={CALENDLY_URL} target="_blank" rel="noopener noreferrer" class="block py-2 text-primary font-bold mobile-nav-link">Agendar</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-nav-link');

  function closeMenu() {
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    toggle?.setAttribute('aria-expanded', String(!menu?.classList.contains('hidden')));
  });

  links.forEach((link) => link.addEventListener('click', closeMenu));
</script>
