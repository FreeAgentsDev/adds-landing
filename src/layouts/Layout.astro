---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const { title = 'FreeAgents | Full Business Growth', description = 'Construimos tecnología que hace crecer negocios. Desarrollo a medida, optimización de procesos y estrategia digital.', image = '/fa-logo.png' } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = siteUrl ? `${siteUrl}${Astro.url.pathname}` : '';
const ogImageUrl = siteUrl ? `${siteUrl}${image.startsWith('/') ? image : `/${image}`}` : '';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/fa-logo.png" />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <!-- Open Graph (og:image y og:url requieren URL absoluta; configura site en astro.config.mjs) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="FreeAgents" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
